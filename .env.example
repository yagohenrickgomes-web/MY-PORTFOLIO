# Copie este arquivo para ".env" (sem o ".example") e preencha com seus dados reais.
# O arquivo .env NUNCA deve ser commitado no Git (já está no .gitignore).

# String de conexão do PostgreSQL local:
# postgresql://usuario:senha@localhost:5432/nome_do_banco
DATABASE_URL=postgresql://postgres:sua_senha@localhost:5432/portfolio

# Chave usada para assinar o cookie de sessão do admin.
# Gere uma localmente com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_por_uma_chave_aleatoria_longa
